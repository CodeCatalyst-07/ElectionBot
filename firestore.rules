rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions collection: only server-side Admin SDK can read/write.
    // Client SDK access is disabled entirely — all reads/writes
    // flow through the Express backend using firebase-admin.
    match /sessions/{sessionId} {
      allow read, write: if false;
    }

    // Deny all other document access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
