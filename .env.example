# =============================================
# ELECTION ASSISTANT — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to server/.env and fill in values
# Lines marked REQUIRED must be set for the app to run
# Lines marked OPTIONAL enable extra features but have fallbacks

# -----------------------------------------------
# GOOGLE GEMINI AI (REQUIRED)
# Get from: https://aistudio.google.com/app/apikey
# -----------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------
# GOOGLE TRANSLATE API (OPTIONAL)
# Without this key, the app runs in English only
# Get from: https://console.cloud.google.com/apis/library/translate.googleapis.com
# -----------------------------------------------
GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here

# -----------------------------------------------
# GOOGLE TEXT-TO-SPEECH API (OPTIONAL)
# Without this key, the app uses browser Web Speech API as fallback
# Get from: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# -----------------------------------------------
GOOGLE_TTS_API_KEY=your_tts_api_key_here

# -----------------------------------------------
# GOOGLE CALENDAR OAuth2 (OPTIONAL)
# Without these, the Calendar button shows a graceful "Coming Soon" UI
# Get from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------
GOOGLE_CALENDAR_CLIENT_ID=your_calendar_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_calendar_client_secret_here
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/api/calendar/callback

# -----------------------------------------------
# FIREBASE (REQUIRED for chat history persistence)
# Without these, the app uses in-memory session storage
# Get from: Firebase Console > Project Settings > Service Accounts
# -----------------------------------------------
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# -----------------------------------------------
# SERVER CONFIG
# -----------------------------------------------
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
